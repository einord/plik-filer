# Application
NODE_ENV=production
NUXT_PUBLIC_APP_NAME=plik Filer

# Security — CHANGE THIS to a long random string
NUXT_JWT_SECRET=change-this-to-a-random-secret

# File storage path inside container
NUXT_DATA_PATH=/app/data

# SQLite database path inside container
NUXT_DATABASE_PATH=/app/database/plik.db

# Public origin URL — your domain with HTTPS
NUXT_ORIGIN=https://files.example.com
